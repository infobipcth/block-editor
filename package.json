{
  "name": "@van-ons/block-editor",
  "version": "1.1.0",
  "description": "A standalone implementation of the WordPress Block Editor",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "block",
    "editor",
    "gutenberg",
    "block-editor"
  ],
  "author": "Maurice Wijnia",
  "contributors": ["Denis Žoljom"],
  "license": "GPL-2.0-or-later",
  "files": [
    "dist/"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "watch": "npm run build:ts -- --watch & npm run build:sass -- --watch",
    "start": "vite playground",
    "prebuild": "npm run clean",
    "build": "npm run build:ts && npm run build:sass",
    "build:sass": "sass src/styles.scss dist/styles.css",
    "build:ts": "tsc",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@wordpress/api-fetch": "^7.43.0",
    "@wordpress/base-styles": "^6.19.0",
    "@wordpress/block-editor": "^15.16.0",
    "@wordpress/block-library": "^9.43.0",
    "@wordpress/blocks": "^15.16.0",
    "@wordpress/components": "^32.5.0",
    "@wordpress/data": "^10.43.0",
    "@wordpress/element": "^6.43.0",
    "@wordpress/format-library": "^5.43.0",
    "@wordpress/hooks": "^4.43.0",
    "@wordpress/keyboard-shortcuts": "^5.43.0",
    "@wordpress/server-side-render": "^6.19.0",
    "axios": "^1.15.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "sass": "^1.99.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/infobipcth/block-editor.git"
  },
  "bugs": {
    "url": "https://github.com/infobipcth/block-editor/issues"
  },
  "homepage": "https://github.com/infobipcth/block-editor#readme"
}
